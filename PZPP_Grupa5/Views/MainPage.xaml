<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PZPP_Grupa5.Views.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30,50" Spacing="20">

            <Entry Placeholder="Wklej link do YouTube..." 
           Text="{Binding VideoUrl}" 
           ClearButtonVisibility="WhileEditing" />

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding ChceStreszczenie}" />
                <Label Text="Skrócony opis" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding ChceWniosek}" />
                <Label Text="Wnioski" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding ChceTimestamps}" />
                <Label Text="Ważne punkty (Timestamps)" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Text="Przetwarzaj wideo" 
            Command="{Binding ProcessVideoCommand}" />

            <ScrollView HeightRequest="300">
                <Label Text="{Binding TekstWynikowy}" />
            </ScrollView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
