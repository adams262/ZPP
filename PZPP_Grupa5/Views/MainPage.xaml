<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PZPP_Grupa5.Views.MainPage"
             BackgroundColor="{StaticResource Gray950}"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="25" HorizontalOptions="Center" MaximumWidthRequest="500">

                <Label Text="AI analiza wideo"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="DarkViolet"
                       HorizontalOptions="Center"
                       Margin="0,30,0,10"/>

                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource Gray900}" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Link do filmu z Youtube:" TextColor="BlueViolet" FontSize="20"/>
                        <Entry Placeholder="https://www.youtube.com/..."
                               Text="{Binding VideoUrl}"
                               TextColor="White"
                               PlaceholderColor="{StaticResource Gray600}"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource Gray900}" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Opcje analizy:" TextColor="DarkViolet" FontSize="20" FontAttributes="Bold" Margin="0,0,0,5"/>
                        <HorizontalStackLayout Spacing="15">
                            <CheckBox IsChecked="{Binding ChceStreszczenie}" Color="DarkViolet" />
                            <Label Text="Skrócony opis" VerticalOptions="Center" TextColor="White" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="15">
                            <CheckBox IsChecked="{Binding ChceWniosek}" Color="DarkViolet" />
                            <Label Text="Kluczowe wnioski" VerticalOptions="Center" TextColor="White" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="15">
                            <CheckBox IsChecked="{Binding ChceTimestamps}" Color="DarkViolet" />
                            <Label Text="Ważne punkty (Timestamps)" VerticalOptions="Center" TextColor="White" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Przetwarzaj wideo" 
                        Command="{Binding ProcessVideoCommand}"
                        BackgroundColor="DarkViolet"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="25" 
                        HeightRequest="60"
                        WidthRequest="240"
                        HorizontalOptions="Center"
                        Shadow="{Shadow Brush=Black, Offset='0,5', Radius=10, Opacity=0.3}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Text" Value="Pracuję..." />
                            <Setter Property="Opacity" Value="0.6" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Label Text="Wynik analizy:" TextColor="DarkViolet" FontSize="20" FontAttributes="Bold" Margin="0,10,0,0" />

                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray900}" HeightRequest="350" Padding="15">
                    <ScrollView>
                        <Label Text="{Binding TekstWynikowy}" TextColor="{StaticResource Gray200}" LineHeight="1.4" FontSize="15"/>
                    </ScrollView>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" 
              InputTransparent="False" 
              ZIndex="10"
              HorizontalOptions="Fill" 
              VerticalOptions="Fill">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#8e44ad" Offset="0.1" />
                    <GradientStop Color="#1a1a1a" Offset="0.9" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="30">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   Color="White" 
                                   WidthRequest="100" 
                                   HeightRequest="100" />

                <Label Text="{Binding TekstWynikowy}" 
                       TextColor="White" 
                       FontSize="22" 
                       HorizontalTextAlignment="Center"
                       FontAttributes="Italic"
                       Margin="30,0"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>